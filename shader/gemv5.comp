#version 450
#define TS 256
#define vec 4
#define GB 4
#extension GL_EXT_shader_explicit_arithmetic_types_float16 : require

layout(local_size_x = TS, local_size_y = 1, local_size_z = 1) in;

layout(push_constant) uniform Dimensions {
    uint M;
    uint N;
    uint K;
} dims;

layout(set = 0, binding = 0) readonly restrict buffer MatrixA { vec4 A[]; };
layout(set = 0, binding = 1) readonly restrict buffer MatrixB { vec4 B[]; };
layout(set = 0, binding = 2) writeonly restrict buffer MatrixC { float C[]; };

shared vec4 Asub[TS];
shared float accSum[TS/2];

void main() {
    uint groupSize = TS / GB;
    uint groupId = gl_LocalInvocationID.x / groupSize;
    uint col = gl_LocalInvocationID.x % groupSize;
    uint globalCol = gl_WorkGroupID.x * groupSize + col;
    uint localId = gl_LocalInvocationID.x;
    if (globalCol >= dims.N) return;

    float acc = 0.0;
    uint numTiles = (dims.K + TS - 1) / TS / vec;
    for (uint t = 0; t < numTiles; t++) {
        uint tiledColA = t * TS + localId;
        Asub[localId] = A[tiledColA];
        barrier();
        for (uint k = 0; k < TS / GB; k++) {
            uint row = t * TS + k * GB + groupId;
            acc += dot(Asub[k * GB + groupId], B[row * dims.N + globalCol]);
        }
        barrier();
    }

    if (GB > 1) {
        uint stride = TS / 2;
        for (uint s = 0; stride >= groupSize; s++) {
            if (localId >= stride) {
                accSum[localId - stride] = acc;
            }
            barrier();
            if (localId < stride) {
                acc += accSum[localId];
            }
            barrier();
            stride /= 2;
        }
    }

    if (globalCol < dims.N && groupId == 0) {
        C[globalCol] = acc;
    }
}
