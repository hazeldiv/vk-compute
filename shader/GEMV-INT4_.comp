            aSub[nxt][col] = A[(t + 1) * TS + col];
            scaleSub[nxt][col] = scale[(t + 1) * TS / 4 + scaleIdx];
            zeroSub[nxt][col] = zeroPoint[(t + 1) * TS / 4 + scaleIdx];
        }

        // Original INT8 inner loop: k += 4, baseRow += dims.N
        // INT4 inner loop: k += 8, baseRow += stride
        #pragma unroll
        for (uint k = 0; k < TS; k += 8) {
