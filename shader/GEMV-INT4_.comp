#version 450
#define TS 256
#define GROUP_SIZE 256
#extension GL_EXT_shader_explicit_arithmetic_types_float16 : require

layout(local_size_x = TS, local_size_y = 1, local_size_z = 1) in;

layout(push_constant) uniform Dimensions {
    uint M;
    uint N;
    uint K;
} dims;

layout(set = 0, binding = 0) readonly restrict buffer MatrixA { vec4 A[]; };
layout(set = 0, binding = 1) readonly restrict buffer MatrixB { uint B[]; };
layout(set = 0, binding = 2) writeonly restrict buffer MatrixC { float C[]; };
layout(set = 0, binding = 3) readonly restrict buffer MatrixD { vec4 scale[]; };
layout(set = 0, binding = 4) readonly restrict buffer MatrixE { vec4 zeroPoint[]; };

shared vec4 aSub[2][TS];
shared vec4 scaleSub[2][TS];
shared vec4 zeroSub[2][TS];

const uvec4 lowShifts  = uvec4(0, 4, 8, 12);
const uvec4 highShifts = uvec4(16, 20, 24, 28);

// Unpack 8 int4 values from 4 bytes packed in a uint
// Each byte contains 2 int4 values: upper nibble (q0) and lower nibble (q1)
// Returns: q0 in first vec4, q1 in second vec4
vec4 unpackInt4x4(uint packedComponent, uvec4 shiftOffsets) {
    // 1. Parallel right-shift across all 4 vector lanes
    uvec4 bits = uvec4(packedComponent) >> shiftOffsets;
    
    // 2. Clear out adjacent bits (0xF = 1111 in binary)
    bits = bits & uvec4(0xF);
    
    // 3. Branchless Sign Extension for INT4 (-8 to 7)
    ivec4 signedInts = ivec4((bits ^ 0x8) - 0x8);
    
    // 4. Cast to FP32 vector
    return vec4(signedInts);
}

