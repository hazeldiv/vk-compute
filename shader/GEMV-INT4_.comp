    uint col = gl_LocalInvocationID.x;
    uint globalCol = gl_WorkGroupID.x * TS + col;
    if (globalCol >= dims.N) return;

    // INT4: 2 values per byte, so stride = N/4 uints
    uint stride = dims.N / 4;

    // Scale index: one scale per GROUP_SIZE values
    // For INT4 with vec4 scale elements, scale idx = workgroup * (K/4) + col
    uint scaleIdx = gl_WorkGroupID.x * dims.K / 4 + col;

    float acc = 0.0f;

    // Number of tiles (matching original INT8 structure)
    uint numTiles = (dims.K + TS - 1) / TS;

    // Load first tile
    aSub[0][col] = A[col];
    scaleSub[0][col] = scale[scaleIdx];
    zeroSub[0][col] = zeroPoint[scaleIdx];

    barrier();
