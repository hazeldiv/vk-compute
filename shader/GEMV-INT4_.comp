            // vec4 w1 = q0.y * scaleSub[cur][k + 1] - zeroSub[cur][k + 1];
            // vec4 w2 = q0.z * scaleSub[cur][k + 2] - zeroSub[cur][k + 2];
            // vec4 w3 = q0.w * scaleSub[cur][k + 3] - zeroSub[cur][k + 3];
            // vec4 w4 = q1.x * scaleSub[cur][k + 4] - zeroSub[cur][k + 4];
            // vec4 w5 = q1.y * scaleSub[cur][k + 5] - zeroSub[cur][k + 5];
            // vec4 w6 = q1.z * scaleSub[cur][k + 6] - zeroSub[cur][k + 6];
            // vec4 w7 = q1.w * scaleSub[cur][k + 7] - zeroSub[cur][k + 7];

            // // Accumulate dot products
            // acc += dot(aSub[cur][k + 0], w0);
            // acc += dot(aSub[cur][k + 1], w1);
            // acc += dot(aSub[cur][k + 2], w2);
            // acc += dot(aSub[cur][k + 3], w3);
            // acc += dot(aSub[cur][k + 4], w4);
            // acc += dot(aSub[cur][k + 5], w5);
            // acc += dot(aSub[cur][k + 6], w6);
            // acc += dot(aSub[cur][k + 7], w7);
            // if (globalCol == 0) C[0] = q0.x;
            // return;
        }

        baseRow += stride;
